# Copy to .env and fill in. Never commit the real .env.

# Metabase API key (Metabase -> Account settings -> API keys). Required.
METABASE_API_KEY=mb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack incoming webhook URL (one channel per webhook). Optional.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx

# Slack bot token (xoxb-...) for chat.postMessage to any channel. Optional.
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx

# Slack app-level token (xapp-...) for the Socket Mode scope-control service. Optional.
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxx

# Shared scope store the control app writes + the scans read. Optional (empty = monitor all).
#   local:  file:///abs/path/scope.json   or a bare path
#   prod:   s3://your-bucket/alerting/scope.json
SARVAM_ALERTING_SCOPE_URI=
